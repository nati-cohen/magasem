{
  "entities": {
    "MenuItem": {
      "title": "MenuItem",
      "description": "A food item on the menu",
      "type": "object",
      "properties": {
        "categoryId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" }
      },
      "required": ["categoryId", "title", "price", "image"]
    }
  },
  "firestore": {
    "menuItems/{itemId}": {
      "schema": { "$ref": "#/entities/MenuItem" },
      "description": "Menu items"
    }
  }
}
