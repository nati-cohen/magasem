rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && 
             request.auth.token.email_verified == true && 
             request.auth.token.email == "netanel095@gmail.com";
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidMenuItem(data) {
      return data.keys().hasAll(['categoryId', 'title', 'description', 'price', 'image']) &&
             data.keys().size() == 5 &&
             data.categoryId is string && data.categoryId.size() > 0 && data.categoryId.size() <= 64 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 128 &&
             data.description is string && data.description.size() <= 2000 &&
             data.price is number && data.price >= 0 &&
             data.image is string && data.image.size() <= 2048;
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /menuItems/{itemId} {
      // Public menu
      allow read: if true;
      allow list: if true; 
      
      allow create: if isAdmin() && 
                       isValidId(itemId) && 
                       isValidMenuItem(incoming());
                       
      allow update: if isAdmin() && 
                       isValidId(itemId) && 
                       isValidMenuItem(incoming());
                       
      allow delete: if isAdmin() && isValidId(itemId);
    }
  }
}
